// ClinicFlow — clinic management system.
// SQLite for zero-config local runs; switch `provider` to "postgresql" for prod.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  STAFF
  ADMIN
  DOCTOR
  RECEPTIONIST
}

enum AppointmentStatus {
  BOOKED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum RecordKind {
  VISIT
  NOTE
  DIAGNOSIS
  LAB
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(STAFF)
  createdAt    DateTime @default(now())
}

model Provider {
  id           String        @id @default(cuid())
  name         String
  specialty    String
  workStartMin Int           @default(540)
  workEndMin   Int           @default(1020)
  slotMinutes  Int           @default(30)
  active       Boolean       @default(true)
  appointments Appointment[]
}

model Patient {
  id           String          @id @default(cuid())
  name         String
  email        String?
  phone        String?
  dob          DateTime?
  gender       String?
  bloodType    String?
  allergies    String?
  address      String?
  notes        String?
  createdAt    DateTime        @default(now())
  appointments Appointment[]
  records      MedicalRecord[]
  invoices     Invoice[]
}

model MedicalRecord {
  id         String     @id @default(cuid())
  patient    Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId  String
  kind       RecordKind @default(NOTE)
  title      String
  details    String?
  authorName String?
  createdAt  DateTime   @default(now())

  @@index([patientId])
}

model Appointment {
  id         String            @id @default(cuid())
  provider   Provider          @relation(fields: [providerId], references: [id])
  providerId String
  patient    Patient           @relation(fields: [patientId], references: [id])
  patientId  String
  date       DateTime
  startMin   Int
  endMin     Int
  status     AppointmentStatus @default(BOOKED)
  reason     String?
  createdAt  DateTime          @default(now())

  @@index([providerId, date])
  @@index([date])
}

enum InvoiceStatus {
  UNPAID
  PAID
  VOID
}

model Invoice {
  id         String        @id @default(cuid())
  number     String        @unique
  patient    Patient       @relation(fields: [patientId], references: [id])
  patientId  String
  status     InvoiceStatus @default(UNPAID)
  currency   String        @default("AED")
  // Denormalized total (minor units) computed from items at write time.
  totalCents Int           @default(0)
  notes      String?
  dueAt      DateTime?
  issuedAt   DateTime      @default(now())
  items      InvoiceItem[]

  @@index([status])
  @@index([issuedAt])
}

model InvoiceItem {
  id             String  @id @default(cuid())
  invoice        Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId      String
  description    String
  quantity       Int
  unitPriceCents Int
}
